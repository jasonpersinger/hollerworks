rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if resource.data.status == "approved";
      allow create: if false;
      allow update, delete: if false;
    }
    match /mail/{docId} {
      allow read, write: if false;
    }
  }
}
